# Copy to .env and fill in. Phases 0–2 run with just PORT + DATABASE_URL.
PORT=8787
NODE_ENV=development
DATABASE_URL=postgres://relay:relay@localhost:5432/relay

# Auth (Phase 1) — shared secret for signing session tokens
JWT_SECRET=dev-only-change-me

# Twilio (Phase 3) — sending stays mocked until these are set
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# AI (Phase 5) — set one provider
ANTHROPIC_API_KEY=
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1

# WhatsApp Business Cloud API (Phase 7)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=relay-verify

# RevenueCat billing webhook (Phase 6) — the Authorization header value you set in RevenueCat
REVENUECAT_AUTH_HEADER=
